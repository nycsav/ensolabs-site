# Signal Lens demo — environment variables
#
# The live pipeline (Perplexity sources signals -> Claude scores them against the
# lens rules) reads these. Without them, the demo still runs on local sample data
# and the "Fetch live signals" button returns a clear "add your keys" message.
#
# To enable live mode: copy this file to `.env.local` (gitignored), paste real
# values, and restart the dev server. Keys are read on the SERVER ONLY — never
# prefix them with NEXT_PUBLIC_ and never commit `.env.local`.

# Perplexity API — sources recent, web-grounded signals. Required for live mode.
PERPLEXITY_API_KEY=

# Anthropic / Claude API — scores each signal against the lens rules. Required for live mode.
ANTHROPIC_API_KEY=

# --- Optional overrides (sensible defaults if unset) ---
# Claude model used for scoring (default: claude-opus-4-8)
# SIGNAL_LENS_MODEL=claude-opus-4-8
# Perplexity model used for sourcing (default: sonar)
# PERPLEXITY_MODEL=sonar
