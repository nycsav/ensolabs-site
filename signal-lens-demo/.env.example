# Signal Lens demo — environment variables
#
# NOTE: The demo as scaffolded runs entirely on local sample data and needs
# NONE of these. They are placeholders for an OPTIONAL live-enrichment layer
# (e.g. a Perplexity + Claude pipeline) that is not wired up yet.
#
# To use: copy this file to `.env.local` (gitignored) and fill in real values.
# Keys must be read on the server only — never expose them to the client / NEXT_PUBLIC_.

# Perplexity API (signal sourcing)
PERPLEXITY_API_KEY=

# Anthropic / Claude API (signal scoring + summarization)
ANTHROPIC_API_KEY=
